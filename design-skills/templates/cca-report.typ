// CCA Status Report Template
// Usage: typst compile --input data=report.json cca-report.typ output.pdf
// Or: typst compile cca-report.typ (uses embedded sample data for testing)

// --- Color Palette ---
#let primary = rgb("#1a1a2e")
#let accent = rgb("#0f3460")
#let highlight = rgb("#e94560")
#let success = rgb("#16c79a")
#let muted = rgb("#6b7280")
#let surface = rgb("#f8f9fa")
#let border = rgb("#e5e7eb")
#let warning = rgb("#f59e0b")

// --- Data Loading ---
#let data = if sys.inputs.keys().contains("data") {
  json(sys.inputs.data)
} else {
  // Fallback sample data for template testing
  (
    title: "ClaudeCodeAdvancements",
    subtitle: "Project Status Report",
    date: "2026-03-18",
    session: 41,
    summary: (
      total_tests: 1525,
      passing_tests: 1525,
      test_suites: 37,
      total_modules: 8,
      total_findings: 215,
      total_papers: 21,
      master_tasks: 19,
      completed_tasks: 6,
    ),
    modules: (
      (name: "Memory System", path: "memory-system/", status: "COMPLETE", tests: 94, items: "MEM-1-5"),
      (name: "Spec System", path: "spec-system/", status: "COMPLETE", tests: 90, items: "SPEC-1-6"),
      (name: "Context Monitor", path: "context-monitor/", status: "COMPLETE", tests: 197, items: "CTX-1-6"),
      (name: "Agent Guard", path: "agent-guard/", status: "COMPLETE", tests: 264, items: "AG-1-7"),
      (name: "Usage Dashboard", path: "usage-dashboard/", status: "COMPLETE", tests: 196, items: "USAGE-1-3"),
      (name: "Reddit Intelligence", path: "reddit-intelligence/", status: "ACTIVE", tests: 263, items: "MT-6,9,11,14,15"),
      (name: "Self-Learning", path: "self-learning/", status: "ACTIVE", tests: 314, items: "MT-7,10,12"),
      (name: "Research", path: "research/", status: "ACTIVE", tests: 29, items: "Reddit scout"),
    ),
    master_tasks: (
      (id: "MT-0", name: "Kalshi Self-Learning", status: "Phase 1 COMPLETE"),
      (id: "MT-2", name: "Mermaid Diagrams", status: "COMPLETE"),
      (id: "MT-3", name: "Virtual Design Team", status: "COMPLETE"),
      (id: "MT-4", name: "Design Vocabulary", status: "COMPLETE"),
      (id: "MT-6", name: "Nuclear at Will", status: "COMPLETE"),
      (id: "MT-7", name: "Trace Analysis", status: "COMPLETE"),
      (id: "MT-9", name: "Autonomous Scanning", status: "Phase 2 COMPLETE"),
      (id: "MT-10", name: "YoYo Self-Learning", status: "Phase 1 + QualityGate"),
      (id: "MT-11", name: "GitHub Intelligence", status: "Phase 1 COMPLETE"),
      (id: "MT-12", name: "Paper Scanner", status: "Phase 1 COMPLETE"),
      (id: "MT-17", name: "UI/Design Excellence", status: "Phase 1 IN PROGRESS"),
      (id: "MT-18", name: "Academic Writing", status: "Not started"),
    ),
    next_priorities: (
      "MT-17 Phase 1: Typst templates + report generator",
      "Deep-read remaining NEEDLEs (~100 unreviewed)",
      "MT-17 Phase 2: Additional report types",
    ),
  )
}

// --- Status indicator function ---
#let status-dot(status) = {
  if status == "COMPLETE" {
    text(fill: success, weight: "bold")[#sym.circle.filled]
  } else if status.contains("ACTIVE") or status.contains("IN PROGRESS") or status.contains("Phase") {
    text(fill: accent, weight: "bold")[#sym.circle.stroked.tiny]
  } else {
    text(fill: muted)[#sym.circle.stroked]
  }
}

// --- Page Setup ---
#set page(
  paper: "a4",
  margin: (top: 24mm, bottom: 20mm, left: 20mm, right: 20mm),
  header: context {
    if counter(page).get().first() > 1 {
      set text(size: 9pt, fill: muted)
      grid(
        columns: (1fr, 1fr),
        align: (left, right),
        text(weight: "bold", fill: accent)[CCA Status Report],
        [Session #data.session — #data.date],
      )
      line(length: 100%, stroke: 0.5pt + border)
    }
  },
  footer: {
    set text(size: 8pt, fill: muted)
    grid(
      columns: (1fr, 1fr, 1fr),
      align: (left, center, right),
      [ClaudeCodeAdvancements],
      context [Page #counter(page).display()],
      [Generated by Typst],
    )
  },
)

#set text(font: "Helvetica Neue", size: 11pt, fill: primary)
#set par(leading: 0.7em)

// --- Title Page ---
#v(40mm)

#align(center)[
  #text(size: 32pt, weight: "bold", fill: accent)[#data.title]
  #v(4mm)
  #text(size: 18pt, fill: muted)[#data.subtitle]
  #v(8mm)
  #line(length: 60%, stroke: 2pt + accent)
  #v(8mm)
  #text(size: 14pt, fill: muted)[
    Session #data.session #h(1em) | #h(1em) #data.date
  ]
]

#v(30mm)

// --- Summary Cards ---
#let metric-card(label, value, color: accent) = {
  box(
    width: 100%,
    fill: surface,
    stroke: 1pt + border,
    radius: 4pt,
    inset: 12pt,
  )[
    #text(size: 9pt, fill: muted, weight: "semibold")[#upper(label)]
    #v(2mm)
    #text(size: 22pt, weight: "bold", fill: color)[#value]
  ]
}

#grid(
  columns: (1fr, 1fr, 1fr, 1fr),
  column-gutter: 12pt,
  metric-card("Tests Passing", [#data.summary.passing_tests / #data.summary.total_tests], color: success),
  metric-card("Test Suites", str(data.summary.test_suites)),
  metric-card("Modules", str(data.summary.total_modules)),
  metric-card("Findings", str(data.summary.total_findings)),
)

#v(6mm)

#grid(
  columns: (1fr, 1fr, 1fr, 1fr),
  column-gutter: 12pt,
  metric-card("Papers Logged", str(data.summary.total_papers)),
  metric-card("Master Tasks", str(data.summary.master_tasks)),
  metric-card("Completed", str(data.summary.completed_tasks), color: success),
  metric-card("Active", str(data.summary.master_tasks - data.summary.completed_tasks), color: accent),
)

#pagebreak()

// --- Module Status ---
#text(size: 16pt, weight: "bold", fill: accent)[Module Status]
#v(2mm)
#line(length: 100%, stroke: 0.5pt + border)
#v(4mm)

#table(
  columns: (auto, 2fr, 1fr, auto, 1.5fr),
  stroke: 0.5pt + border,
  fill: (_, row) => if row == 0 { accent } else if calc.odd(row) { surface } else { white },
  align: (center, left, center, center, left),
  inset: 8pt,

  // Header
  text(fill: white, weight: "bold", size: 10pt)[],
  text(fill: white, weight: "bold", size: 10pt)[Module],
  text(fill: white, weight: "bold", size: 10pt)[Status],
  text(fill: white, weight: "bold", size: 10pt)[Tests],
  text(fill: white, weight: "bold", size: 10pt)[Components],

  // Data rows
  ..for mod in data.modules {
    (
      status-dot(mod.status),
      text(weight: "semibold")[#mod.name],
      text(size: 10pt)[#mod.status],
      text(size: 10pt, font: "Menlo")[#mod.tests],
      text(size: 9pt, fill: muted)[#mod.items],
    )
  }
)

#v(8mm)

// --- Master Tasks ---
#text(size: 16pt, weight: "bold", fill: accent)[Master Tasks]
#v(2mm)
#line(length: 100%, stroke: 0.5pt + border)
#v(4mm)

#table(
  columns: (auto, auto, 2fr, 2fr),
  stroke: 0.5pt + border,
  fill: (_, row) => if row == 0 { accent } else if calc.odd(row) { surface } else { white },
  align: (center, left, left, left),
  inset: 8pt,

  text(fill: white, weight: "bold", size: 10pt)[],
  text(fill: white, weight: "bold", size: 10pt)[ID],
  text(fill: white, weight: "bold", size: 10pt)[Task],
  text(fill: white, weight: "bold", size: 10pt)[Status],

  ..for task in data.master_tasks {
    (
      status-dot(task.status),
      text(font: "Menlo", size: 10pt)[#task.id],
      text(weight: "semibold")[#task.name],
      text(size: 10pt)[#task.status],
    )
  }
)

#v(8mm)

// --- Next Priorities ---
#text(size: 16pt, weight: "bold", fill: accent)[Next Priorities]
#v(2mm)
#line(length: 100%, stroke: 0.5pt + border)
#v(4mm)

#for (i, priority) in data.next_priorities.enumerate() {
  box(
    width: 100%,
    fill: surface,
    stroke: 1pt + border,
    radius: 4pt,
    inset: 10pt,
  )[
    #text(size: 12pt, weight: "bold", fill: accent)[#(i + 1).] #h(4pt)
    #text(size: 11pt)[#priority]
  ]
  v(4mm)
}

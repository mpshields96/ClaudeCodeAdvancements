{
  "_comment": "Trigger-table optimized skill routing (S54). Compact keyword matching replaces verbose regex. Each rule maps intent signals to skill activation with minimal token overhead.",
  "_optimization": "Trigger-table pattern from S52 research: 54% context reduction by using compact routing tables instead of verbose skill descriptions. Rules fire via keyword match first (O(1)), regex only as fallback.",
  "rules": [
    {
      "id": "spec-new-feature",
      "skill": "/spec:requirements",
      "keywords": ["new feature", "build a", "create a", "implement a", "add a new", "design a", "architect"],
      "intent_patterns": ["(?i)\\b(build|create|implement|design|add)\\b.*\\b(system|module|feature|service|api|component|app|tool|dashboard|hook)\\b"],
      "exclude_patterns": ["(?i)\\b(fix|bug|patch|hotfix|debug|test|refactor)\\b"],
      "message": "New feature detected. Run /spec:requirements first — spec-first reduces rework by 60-80%.",
      "priority": 10,
      "enabled": true
    },
    {
      "id": "spec-design-needed",
      "skill": "/spec:design",
      "keywords": ["how should I structure", "architecture for", "what pattern", "design pattern", "how to organize"],
      "intent_patterns": ["(?i)\\b(structur|architect|organiz|design|pattern)\\b.*\\b(code|project|module|system|app)\\b"],
      "exclude_patterns": [],
      "message": "Architecture question. If you have approved requirements, run /spec:design.",
      "priority": 8,
      "enabled": true
    },
    {
      "id": "debug-systematic",
      "skill": "systematic-debugging",
      "keywords": ["bug", "broken", "not working", "error", "crash", "failing", "doesn't work", "wrong output"],
      "intent_patterns": ["(?i)\\b(bug|broken|crash|fail|error|wrong|unexpected)\\b"],
      "exclude_patterns": ["(?i)\\b(new feature|build|create|implement)\\b"],
      "message": "Bug detected. Systematic debugging: reproduce > hypothesize > test > fix.",
      "priority": 7,
      "enabled": true
    },
    {
      "id": "tdd-reminder",
      "skill": "test-driven-development",
      "keywords": ["write the code", "implement this", "code this up", "start coding", "let's build"],
      "intent_patterns": ["(?i)\\b(write|code|implement|start|build)\\b.*\\b(code|function|class|method|module)\\b"],
      "exclude_patterns": ["(?i)\\b(test|spec|design|review|read)\\b"],
      "message": "Write tests first (TDD). Tests define the contract before implementation.",
      "priority": 5,
      "enabled": true
    },
    {
      "id": "kalshi-research",
      "skill": "kalshi-research-bridge",
      "keywords": ["kalshi", "prediction market", "bet sizing", "kelly criterion", "calibration", "edge detection"],
      "intent_patterns": ["(?i)\\b(kalshi|prediction|betting|kelly|calibrat)\\b"],
      "exclude_patterns": [],
      "message": "Trading/Kalshi topic detected. Check KALSHI_INTEL.md and CCA_TO_POLYBOT.md for relevant research.",
      "priority": 6,
      "enabled": true
    },
    {
      "id": "review-url",
      "skill": "/cca-review",
      "keywords": [],
      "intent_patterns": ["https?://[^\\s]+"],
      "exclude_patterns": ["(?i)\\b(don't review|just read|no review|skip review)\\b"],
      "message": "URL detected. Running /cca-review.",
      "priority": 9,
      "enabled": false,
      "_note": "Disabled — URL auto-review handled by CLAUDE.md rules"
    }
  ],
  "settings": {
    "max_activations_per_prompt": 2,
    "cooldown_seconds": 0,
    "log_activations": true,
    "disabled": false
  }
}
